#!/bin/sh
# math-coding — math-coding v0.978 dispatcher.
#
# Routes user-facing commands to the right tool. The dispatcher
# knows the layout; the tools know their role.

set -u

. "$(dirname "$0")/core/lib/common.sh"

usage() {
    cat <<EOF
usage: math-coding <command> [args...]

Commands:
  create <name> --from <spec.yaml>
                   Create a packet from a YAML spec (file or '-').
                   Spec has 7 fields: proposition, outcome,
                   invariant, test, antithesis, synthesis, operation.
  extract <name>    Emit a YAML spec for an existing packet to stdout.
  apply <name>      Record SHA witness and transition to applied.
  review <name>     Peer-review: --approve | --request-changes |
                   --comment. v0.991: applied needs >=1 approve.
  retire <name> --reason=<supersession|deprecation>
                   Transition to retired.
  abandon <name>    Transition draft → abandoned (v0.991).
  amend <name> --reason="<text>"
                   Record a formal amendment to a packet
                   (append to amendments[]). v0.992.
  lifecycle <name> <state>
                   Unified state transition. <state> ∈
                   applied | retired | abandoned. Aliases
                   to apply, retire, abandon.
  stable <name>    Mark packet as stable_since today (opt-in).
  archive <name> [--confirm]
                   Move to math/archived/, preserve git history.
  verify [--cross-packet-consistency]
                   Run core/check/verify.sh on all packets.
                   --cross-packet-consistency also runs cross-packet
                   DAG checks (depends_on, supersession, amendments).
  drift-check       Run core/check/drift-check.sh on applications[].
  probe             Run core/self/probe.sh (axiom A6 self-application).
  install <path> [--gitignore]
                   Install convention to <path>/.math-coding/.
                   By default .math-coding/ is committed.
                   --gitignore opts in to gitignore behavior.
  install-skill    Install math-coding skill to agent's skills
                   location (default: opencode). See
                   core/install/install-skill.sh.
  config           Interactive .mathrc editor. Asks for each
                   field (Enter to keep). TTY-aware.
  upgrade <path>    Upgrade .math-coding/ in <path>.
  uninstall <path>  Remove .math-coding/ from <path>.
  help              This message.

Examples:
  sh math-coding create my-feature --from spec.yaml
  sh math-coding apply my-feature
  sh math-coding verify
  sh math-coding probe
  sh math-coding install /path/to/project

EOF
}

case "${1:-help}" in
    create)
        shift
        exec sh "$REPO_ROOT/core/author/create-packet.sh" "$@"
        ;;
    extract)
        shift
        exec sh "$REPO_ROOT/core/author/extract-packet.sh" "$@"
        ;;
    apply)
        shift
        exec sh "$REPO_ROOT/core/author/apply-packet.sh" "$@"
        ;;
    review)
        shift
        exec sh "$REPO_ROOT/core/author/review-packet.sh" "$@"
        ;;
    retire)
        shift
        exec sh "$REPO_ROOT/core/author/retire-packet.sh" "$@"
        ;;
    abandon)
        shift
        exec sh "$REPO_ROOT/core/author/abandon-packet.sh" "$@"
        ;;
    amend)
        shift
        exec sh "$REPO_ROOT/core/author/amend-packet.sh" "$@"
        ;;
    lifecycle)
        shift
        name="$1"
        state="$2"
        if [ -z "$name" ] || [ -z "$state" ]; then
            echo "usage: math-coding lifecycle <name> <state>" >&2
            echo "  state: applied | retired | abandoned" >&2
            exit 2
        fi
        shift 2
        case "$state" in
            applied)
                exec sh "$REPO_ROOT/core/author/apply-packet.sh" "$name" "$@"
                ;;
            retired)
                exec sh "$REPO_ROOT/core/author/retire-packet.sh" "$name" "$@"
                ;;
            abandoned)
                exec sh "$REPO_ROOT/core/author/abandon-packet.sh" "$name" "$@"
                ;;
            draft)
                echo "error: cannot transition to 'draft' (use create for new packet)" >&2
                exit 1
                ;;
            *)
                echo "error: unknown state '$state' (use: applied|retired|abandoned)" >&2
                exit 1
                ;;
        esac
        ;;
    stable)
        shift
        exec sh "$REPO_ROOT/core/author/stable.sh" "$@"
        ;;
    archive)
        shift
        exec sh "$REPO_ROOT/core/author/archive-packet.sh" "$@"
        ;;
    verify)
        shift
        exec sh "$REPO_ROOT/core/check/verify.sh" "$@"
        ;;
    drift-check)
        exec sh "$REPO_ROOT/core/check/drift-check.sh"
        ;;
    probe)
        exec sh "$REPO_ROOT/core/self/probe.sh"
        ;;
    install)
        shift
        exec sh "$REPO_ROOT/core/install/install.sh" "$@"
        ;;
    install-skill)
        shift
        exec sh "$REPO_ROOT/core/install/install-skill.sh" "$@"
        ;;
    config)
        shift
        exec sh "$REPO_ROOT/core/author/config.sh" "$@"
        ;;
    upgrade)
        shift
        exec sh "$REPO_ROOT/core/install/upgrade.sh" "$@"
        ;;
    uninstall)
        shift
        exec sh "$REPO_ROOT/core/install/uninstall.sh" "$@"
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        echo "math-coding: unknown command '$1'" >&2
        echo "" >&2
        usage >&2
        exit 2
        ;;
esac