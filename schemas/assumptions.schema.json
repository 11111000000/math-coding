{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://math-coding.local/schemas/assumptions.schema.json",
  "title": "Math Coding Assumptions",
  "type": "object",
  "required": ["task_id", "assumptions"],
  "properties": {
    "task_id": { "type": "string" },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "statement", "status", "epistemology"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^A[0-9]+$"
          },
          "statement": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["user-confirmed", "agent-inferred", "open"]
          },
          "epistemology": {
            "type": "string",
            "enum": ["fact", "hypothesis", "judgment", "unknown"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "version": "2.0"
}