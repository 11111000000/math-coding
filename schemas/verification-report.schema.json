{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://math-coding.local/schemas/verification-report.schema.json",
  "title": "Math Coding Verification Report",
  "type": "object",
  "required": ["verdict"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "VERIFIED",
        "NEEDS_REVISION",
        "UNVERIFIABLE:TOOL_MISSING",
        "UNVERIFIABLE:OUT_OF_SCOPE",
        "UNVERIFIABLE:DEFERRED"
      ]
    },
    "verified_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tool": { "type": "string" },
    "evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "errors": {
      "type": "integer",
      "minimum": 0
    },
    "details": { "type": "string" },
    "human_review": {
      "type": "object",
      "required": ["by", "process", "trigger"],
      "properties": {
        "by": { "type": "string" },
        "process": { "type": "string" },
        "trigger": { "type": "string" },
        "re_verification": { "type": "string" }
      }
    }
  },
  "additionalProperties": false,
  "version": "2.0"
}